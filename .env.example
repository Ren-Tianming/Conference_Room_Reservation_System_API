# Docker Compose local/server example.
# Copy this file to .env and replace all secrets before running containers.

ENV=dev
DEBUG=false
LOG_LEVEL=INFO
APP_NAME=conference-room-reservation-system API
API_V1_PREFIX=/api/v1
TZ=Asia/Tokyo

MYSQL_DATABASE=conference_room
MYSQL_USER=conference_user
MYSQL_PASSWORD=change-this-mysql-password
MYSQL_ROOT_PASSWORD=change-this-root-password

SECRET_KEY=change-this-to-a-long-random-secret-at-least-32-chars
ALGORITHM=HS256
JWT_ISSUER=conference-room-api
JWT_AUDIENCE=conference-room-users
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_CLEANUP_INTERVAL_SECONDS=3600
MAX_BOOKING_DURATION_HOURS=8
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

AUTO_CREATE_TABLES=false
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
REQUIRE_REDIS_FOR_LOCKS=false
REQUIRE_REDIS_FOR_TOKEN_BLACKLIST=false

# Optional bootstrap admin. Set only when you need initial admin creation.
# BOOTSTRAP_ADMIN_USERNAME=admin
# BOOTSTRAP_ADMIN_PASSWORD=change-this-admin-password
